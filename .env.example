# Copy this file to .env and fill in real values before running locally.
# Never commit .env to version control.

# Environment
# Use "production" on Railway/Render.
DJANGO_ENV=development

# Django secret key — generate a new one for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me

# DEBUG defaults to False when DJANGO_ENV=production.
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=127.0.0.1,localhost,testserver

# Comma-separated HTTPS origins, e.g.
# CSRF_TRUSTED_ORIGINS=https://coconutwireless.fj,https://www.coconutwireless.fj
CSRF_TRUSTED_ORIGINS=

# Proxy + HTTPS security settings
USE_X_FORWARDED_PROTO=True
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Database — leave blank to use SQLite (local dev only)
# For production use PostgreSQL:
# DATABASE_URL=postgres://user:password@host:5432/coconut_wireless
DATABASE_URL=sqlite:///db.sqlite3

# Email — console backend prints to terminal (good for local dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@coconutwireless.fj

# For production SMTP (e.g. SendGrid, Mailgun):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-api-key

# Observability (optional)
# SENTRY_DSN=https://<key>@o0.ingest.sentry.io/<project>
SENTRY_DSN=
# Sample rate between 0.0 (disabled) and 1.0 (100%)
SENTRY_TRACES_SAMPLE_RATE=0
